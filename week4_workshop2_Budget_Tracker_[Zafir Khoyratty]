        "# Advanced Challenge: Spending Trends\n",
        "print(\"=== Spending Pattern Analyzer ===\")\n",
        "\n",
        "# Simulated weekly spending data\n",
        "weekly_totals = [156.75, 234.50, 198.25, 267.80, 145.60]\n",
        "week_names = [\"Week 1\", \"Week 2\", \"Week 3\", \"Week 4\", \"Week 5\"]\n",
        "\n",
        "print(\"Weekly spending analysis:\")\n",
        "\n",
        "# Challenge 1: Show each week with trend indicator\n",
        "for i in range(len(weekly_totals)):\n",
        "    current_week = weekly_totals[i]\n",
        "\n",
        "    # Compare with previous week (if not first week)\n",
        "    if i > 0:\n",
        "        previous_week = weekly_totals[i-1]\n",
        "\n",
        "        # Trend logic\n",
        "        if current_week > previous_week:\n",
        "            trend = \"📈 Up\"\n",
        "        elif current_week < previous_week:\n",
        "            trend = \"📉 Down\"\n",
        "        else:\n",
        "            trend = \"🔷 Same\"\n",
        "\n",
        "        # Calculate percentage change\n",
        "        change_percent = ((current_week - previous_week) / previous_week) * 100\n",
        "        print(f\"{week_names[i]}: ${current_week:.2f} [{trend}, {change_percent:.1f}%]\")\n",
        "    else:\n",
        "        print(f\"{week_names[i]}: ${current_week:.2f} [Baseline]\")\n",
        "\n",
        "# Challenge 2: Find best and worst spending weeks\n",
        "highest = max(weekly_totals)\n",
        "lowest = min(weekly_totals)\n",
        "best_week = week_names[weekly_totals.index(lowest)]\n",
        "worst_week = week_names[weekly_totals.index(highest)]\n",
        "\n",
        "print(f\"\\n🔥 Highest spending: {worst_week} (${highest:.2f})\")\n",
        "print(f\"🧊 Lowest spending: {best_week} (${lowest:.2f})\")\n",
        "\n",
        "# Challenge 3: Calculate if spending is trending up or down overall\n",
        "if weekly_totals[-1] > weekly_totals[0]:\n",
        "    overall_trend = \"📈 Overall spending increased\"\n",
        "elif weekly_totals[-1] < weekly_totals[0]:\n",
        "    overall_trend = \"📉 Overall spending decreased\"\n",
        "else:\n",
        "    overall_trend = \"🔷 Overall spending stayed the same\"\n",
        "\n",
        "print(f\"\\n{overall_trend} (from ${weekly_totals[0]:.2f} to ${weekly_totals[-1]:.2f})\")\n"
